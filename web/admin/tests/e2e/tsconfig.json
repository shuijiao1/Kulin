{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2023", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "isolatedModules": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": ["@playwright/test"]
    },
    "include": ["**/*.ts"]
}
